{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es6",
    "baseUrl": "./src",
    "paths": {
      "@controller/*": ["controller/*"],
      "@middleware/*": ["middleware/*"],
      "@model/*": ["model/*"],
      "@route/*": ["route/*"],
      "@service/*": ["service/*"],
      "@util/*": ["util/*"]
    }
  },
  "include": ["src/**/*"]
}
